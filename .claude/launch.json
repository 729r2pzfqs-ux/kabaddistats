{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "kabaddi",
      "runtimeExecutable": "python3",
      "runtimeArgs": ["-u", "-c", "import os,http.server,socketserver;p=int(os.environ.get('PORT','8000'));socketserver.TCPServer(('',p),http.server.SimpleHTTPRequestHandler).serve_forever()"],
      "autoPort": true,
      "port": 8000
    }
  ]
}
